# ─── Mateusz OS — Environment Variables ──────────────────────────────────────
# Copy to .env.local and fill in your values

# ─── Dashboard Auth ───────────────────────────────────────────────────────────
# Set a strong password to protect your /os dashboard
DASHBOARD_PASSWORD=your_secret_password_here

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get from: https://app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Anthropic (Claude AI) ────────────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Twilio (WhatsApp) ────────────────────────────────────────────────────────
# Get from: https://console.twilio.com
# WhatsApp sandbox: https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# YOUR WhatsApp number (receives the briefs, sends logs)
OWNER_WHATSAPP_NUMBER=whatsapp:+1XXXXXXXXXX

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://matmarkowski.com
# Used for Twilio webhook validation
WEBHOOK_BASE_URL=https://matmarkowski.com

# ─── Optional: Plaid (Bank connections) ──────────────────────────────────────
# Get from: https://dashboard.plaid.com
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox

# ─── Optional: Social posting ─────────────────────────────────────────────────
# X (Twitter) API v2 — Bearer token for posting
# X_BEARER_TOKEN=
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_SECRET=

# Instagram Graph API
# IG_ACCESS_TOKEN=
# IG_USER_ID=
